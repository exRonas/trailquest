# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trailquest?schema=public"
# Used by Prisma for migrations (bypasses connection pooling, e.g. Neon's pgbouncer
# endpoint). Locally this is just the same URL as DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/trailquest?schema=public"

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# Use long, random strings in production (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
# Token lifetimes (vercel/ms format: 15m, 1h, 7d, 30d ...)
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins. Use * to allow all (dev only).
CORS_ORIGIN="*"
