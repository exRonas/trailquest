# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trailquest?schema=public"
# Used by Prisma for migrations (bypasses connection pooling, e.g. Neon's pgbouncer
# endpoint). Locally this is just the same URL as DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/trailquest?schema=public"

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# Use long, random strings in production (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
# Token lifetimes (vercel/ms format: 15m, 1h, 7d, 30d ...)
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins. Use * to allow all (dev only).
CORS_ORIGIN="*"

# ─── Email (password reset) ────────────────────────────────────────────────
# "smtp" (Gmail App Password, works today with no domain) or "resend" (needs
# a verified sending domain — see docs/ADMIN_WEB_PROGRESS.md Round 21).
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="you@gmail.com"
SMTP_PASSWORD="16-char-app-password"
MAIL_FROM="TrailQuest <you@gmail.com>"
RESEND_API_KEY=""
PASSWORD_RESET_URL_BASE="trailquest://reset-password"

# ─── Push notifications (Firebase Cloud Messaging) ─────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts.
# Local dev: use PATH. Hosts with no writable filesystem (e.g. Render): paste
# the file's raw contents into JSON instead (JSON wins if both are set).
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
FIREBASE_SERVICE_ACCOUNT_JSON=""
