# ─── API ─────────────────────────────────────────────────────────────────────
# Base URL of the TrailQuest backend (no trailing slash).
# Android emulator reaches the host machine via 10.0.2.2.
# iOS simulator can use localhost. A physical device needs your LAN IP.
API_URL=http://10.0.2.2:4000/api

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# PUBLIC access token (pk.*) — used at runtime by the JS SDK.
# Create one at https://account.mapbox.com/access-tokens/
MAPBOX_PUBLIC_TOKEN=pk.your_public_token_here

# Optional: a custom Mapbox style URL (defaults to outdoors style in code).
MAPBOX_STYLE_URL=mapbox://styles/mapbox/outdoors-v12

# NOTE: The SECRET download token (sk.*) used to fetch the native SDK at build
# time is NOT set here. It goes in:
#   - Android: ~/.gradle/gradle.properties  -> MAPBOX_DOWNLOADS_TOKEN=sk....
#   - iOS:     ~/.netrc                      (see mobile/README.md)
