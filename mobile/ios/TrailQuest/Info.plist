	<dict>
	  <!-- Do not change NSAllowsArbitraryLoads to true, or you will risk app rejection! -->
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TrailQuest uses your location to guide you along the route and show your position on the map.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>TrailQuest tracks your route and triggers checkpoint alerts even when the app is in the background or the screen is off.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>TrailQuest tracks your route and triggers checkpoint alerts even when the app is in the background or the screen is off.</string>
	<key>NSMotionUsageDescription</key>
	<string>TrailQuest uses motion activity to improve location accuracy and battery use while tracking.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>UIAppFonts</key>
	<array>
		<string>MaterialCommunityIcons.ttf</string>
	</array>
